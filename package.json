{
  "name": "dialysis-dashboard-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "npm run --workspace=frontend dev",
    "build": "npm run --workspace=frontend build",
    "test": "npm run --workspace=frontend test && npm run --workspace=backend test",
    "server:dev": "npm run --workspace=backend dev",
    "server:seed": "npm run --workspace=backend seed",
    "server:test": "npm run --workspace=backend test",
    "install:all": "npm install"
  }
}